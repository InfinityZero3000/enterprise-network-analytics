# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ena_password

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_TOPIC_COMPANIES=ena.companies
KAFKA_TOPIC_RELATIONSHIPS=ena.relationships
KAFKA_TOPIC_TRANSACTIONS=ena.transactions
KAFKA_TOPIC_ALERTS=ena.alerts

# ─── PySpark ──────────────────────────────────────────────────────────────────
SPARK_MASTER_URL=spark://localhost:7077
SPARK_APP_NAME=EnterpriseNetworkAnalytics

# ─── MinIO / Object Storage ───────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_BUCKET_RAW=ena-raw
MINIO_BUCKET_PROCESSED=ena-processed

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=enterprise-network-analytics

# ─── AI / LLM Integration ─────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyCcQxctX5z8YSUVQbOhOTYKeFOb4eCttF4
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── FastAPI ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Set a non-empty value to enable X-API-Key header authentication.
# Leave empty to disable auth (suitable for local dev).
API_KEY=

# If API is mounted behind gateway prefix (for example /api), set here.
# Keep empty when serving directly from root.
API_ROOT_PATH=

# ─── CORS / Gateway ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# For production, set to exact UI domains instead of '*'.
CORS_ALLOW_ORIGINS=*
# Optional regex for dynamic subdomains, example:
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.your-domain\.com
CORS_ALLOW_ORIGIN_REGEX=
# Must be false when CORS_ALLOW_ORIGINS=* (browser rule)
CORS_ALLOW_CREDENTIALS=false
# Comma-separated list or '*'
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Data Crawlers ────────────────────────────────────────────────────────────

# OpenCorporates — https://api.opencorporates.com/
# Đăng ký free token tại: https://opencorporates.com/users/sign_up
# Free tier: ~500 req/day | Premium: 10 req/s
OPENCORPORATES_API_TOKEN=
OPENCORPORATES_BASE_URL=https://api.opencorporates.com/v0.4

# OpenSanctions — https://api.opensanctions.org
# API key free cho research; xem: https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=
OPENSANCTIONS_BASE_URL=https://api.opensanctions.org

# GLEIF LEI — https://api.gleif.org/api/v1 (không cần auth)
GLEIF_BASE_URL=https://api.gleif.org/api/v1

# OpenOwnership (BODS) — https://api.openownership.org (không cần auth)
OPENOWNERSHIP_BASE_URL=https://api.openownership.org

# World Bank — https://api.worldbank.org/v2 (không cần auth)
WORLDBANK_BASE_URL=https://api.worldbank.org/v2

# Vietnam NBR (masothue.com + thongtin.doanhnghiep.vn — public, không cần auth)
VN_NBR_BASE_URL=https://dangkykinhdoanh.gov.vn/vn/api

# Crawler tunables
CRAWLER_REQUEST_TIMEOUT=30       # seconds
CRAWLER_MAX_RETRIES=3
CRAWLER_RATE_LIMIT_RPS=2.0       # requests per second (global default)
CRAWLER_CONCURRENCY=5            # parallel requests per crawler
